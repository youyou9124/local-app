  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "rootDir": "electron",
    "outDir": "dist-electron/main",
    "skipLibCheck": true
  },
  "include": ["electron"]
}
